<%- include('../../components/layout/header.ejs', { title: 'Tipos de Canchas | PlaySpot', hideNav: true }) %>
<%- include('../../components/layout/admin-sidebar.ejs') %>

<main class="admin-main">
    <%- include('../../components/layout/admin-topbar.ejs') %>

    <div class="admin-content-wrapper p-4 p-lg-5">
        
        <%- include('../../components/layout/alert-error', { error: locals.error }) %>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-4 mb-5">
            <div>
                <h1 class="display-5 fw-black font-headline tracking-tight mb-0 text-dark">Tipos de Canchas</h1>
            </div>
            <div class="d-flex align-items-center gap-3">
                <a href="/admin/court-types/add" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm px-4 py-3 rounded-3 text-white text-decoration-none fw-bold">
                    <i class="bi bi-plus-circle-fill"></i> Agregar Tipo
                </a>
            </div>
        </div>

        <div class="d-flex flex-column gap-3">
            
            <div class="d-none d-md-flex row px-4 py-2 text-muted text-uppercase fw-bold letter-spacing-1" style="font-size: 0.7rem;">
                <div class="col-8">Categoría / Tipo</div>
                <div class="col-4 text-end">Acciones</div>
            </div>

            <% if (courtTypes && courtTypes.length > 0) { %>
                <% courtTypes.forEach(type => { %>
                    <div class="row mx-0 align-items-center px-3 py-3 px-md-4 py-md-4 bg-white rounded-4 shadow-sm mb-3 border">
                        
                        <div class="col-12 col-md-8 d-flex align-items-center gap-4 mb-3 mb-md-0">
                            <div>
                                <h3 class="fs-5 fw-bold font-headline mb-0 text-dark"><%= type.name %></h3>
                            </div>
                        </div>

                        <div class="col-12 col-md-4 d-flex justify-content-md-end gap-2 mt-3 mt-md-0">
                            <a href="/admin/court-types/edit/<%= type.id %>" class="btn btn-light text-secondary rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <form action="/admin/court-types/delete/<%= type.id %>" method="POST" class="m-0" onsubmit="return confirm('¿Seguro de que quieres eliminar este tipo de cancha?');">
                                <button type="submit" class="btn btn-danger bg-danger-subtle text-danger border-0 rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center p-5 bg-surface-container rounded-4 mt-4" style="background-color: var(--ps-surface-container-low, #f3f4f5);">
                    <i class="bi bi-tag fs-1 text-muted mb-3 d-block"></i>
                    <h4 class="fw-bold text-dark">No hay tipos configurados</h4>
                    <p class="text-secondary small">Crea tipos como "Fútbol 11 - Sintético" o "Tenis de Polvo".</p>
                </div>
            <% } %>
        </div>

    </div>

    <%- include('../../components/layout/footer.ejs') %>
</main>
