<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Catálogo - PlaySpot Cliente</title>
    <link rel="stylesheet" href="/client/catalog/catalog.css">
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>PLAYSPOT CLIENT</h2>
                <p>Centro de Reservas</p>
            </div>
            <nav class="sidebar-nav">
                <a href="/client/catalog" class="nav-item active">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6a2 2 0 012-2h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6z"></path><path d="M8 10h8M8 14h4"></path></svg>
                    Catálogo
                </a>
                <a href="/client/bookings" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                    Mis Reservas
                </a>
            </nav>
            <div class="sidebar-footer">
                <a href="/logout" class="nav-item text-danger">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"></path></svg>
                    Cerrar Sesión
                </a>
            </div>
        </aside>

        <main class="main-content">
            <div class="top-header">
                <div class="header-title">
                    <h1>Catálogo de Canchas</h1>
                    <p>Encuentra tu próximo partido.</p>
                </div>
                <div class="header-user">
                    <span>Hola, <%= user.name %></span>
                    <a href="/logout" class="btn-header-logout" title="Cerrar Sesión">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"></path></svg>
                    </a>
                </div>
            </div>

            <div class="container">
                <div class="search-box">
                    <form action="/client/catalog" method="GET" style="display:flex; width:100%; gap: 1rem; align-items:center;">
                        <span style="font-weight: 600; color: #475569; font-size: 0.9rem; text-transform: uppercase;">Filtrar Fecha:</span>
                        <input type="date" name="date" id="date" value="<%= selectedDate %>" required>
                        <button type="submit">Buscar Turnos</button>
                        <% if(selectedDate) { %>
                            <a href="/client/catalog" class="btn-clear">Limpiar</a>
                        <% } %>
                    </form>
                </div>

                <div class="courts-grid">
                    <% courts.forEach(court => { %>
                        <div class="court-card">
                            <img src="<%= court.image_url ? court.image_url : 'https://images.unsplash.com/photo-1543326727-cf6c39e8f84c?q=80&w=600&auto=format&fit=crop' %>" alt="Cancha de deportes" class="court-image">
                            
                            <div class="court-info">
                                <h3 class="court-name"><%= court.name %> 
                                    <span style="font-size: 0.75rem; font-weight: 700; color: #1e3a8a; margin-left: 0.5rem; background: #dbeafe; padding: 0.2rem 0.6rem; border-radius: 999px; text-transform:uppercase;">
                                        <%= court.type ? court.type.name : 'Deporte Varios' %>
                                    </span>
                                    <span style="font-size: 0.75rem; font-weight: 700; color: #b45309; margin-left: 0.5rem; background: #fef3c7; padding: 0.2rem 0.6rem; border-radius: 999px; text-transform:uppercase;">
                                        Calificación: <%= court.avgRating %>
                                    </span>
                                </h3>
                                <div class="court-price">$<%= court.price_per_hour %> / hora</div>
                            </div>
                            
                            <div class="schedules-container">
                                <% if (selectedDate) { %>
                                    <% if (court.availableSchedules && court.availableSchedules.filter(s => s.isAvailable).length > 0) { %>
                                        <form action="/client/bookings" method="POST" class="multi-booking-form">
                                            <div class="schedules-title">Turnos Disponibles</div>
                                            <div class="blocks-grid">
                                                <% court.availableSchedules.filter(s => s.isAvailable).forEach(sched => { %>
                                                    <label class="time-block-label">
                                                        <input type="checkbox" name="schedule_ids" value="<%= sched.id %>" class="schedule-checkbox">
                                                        <span class="time-block" title="Seleccionar turno"><%= sched.start_time.substring(0, 5) %></span>
                                                    </label>
                                                <% }); %>
                                            </div>
                                            <button type="submit" class="btn-book-multiple" disabled>Reservar Turnos Seleccionados</button>
                                        </form>
                                    <% } else { %>
                                        <div style="font-size: 0.875rem; color: #64748b; font-weight: 500; text-align:center;">
                                            No hay turnos disponibles.
                                        </div>
                                    <% } %>
                                <% } else { %>
                                    <div style="font-size: 0.875rem; color: #64748b; font-weight: 500; text-align:center;">
                                        Selecciona una fecha arriba.
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </main>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const forms = document.querySelectorAll('.multi-booking-form');
            forms.forEach(form => {
                const checkboxes = form.querySelectorAll('.schedule-checkbox');
                const btn = form.querySelector('.btn-book-multiple');
                
                checkboxes.forEach(cb => {
                    cb.addEventListener('change', () => {
                        const checkedCount = form.querySelectorAll('.schedule-checkbox:checked').length;
                        btn.disabled = checkedCount === 0;
                        btn.textContent = checkedCount > 0 ? `Reservar ${checkedCount} Turno(s)` : 'Reservar Turnos Seleccionados';
                    });
                });
            });
        });
    </script>
</body>
</html>
