<%- include('../components/layout/header.ejs', { title: 'Catálogo - PlaySpot', styles: ['/client/catalog.css'] }) %>
    <div class="navbar">
        <h1>PlaySpot <span style="font-size: 0.8rem; color: #64748b; margin-left:10px;">CLIENTE</span></h1>
        <span>
            <a href="/client/bookings" style="color: #cbd5e1; text-decoration: none; margin-right: 1.5rem; font-weight: 500;">Mis Reservas</a>
            Hola, <%= user.name %> 
            <a href="/logout" class="btn-logout" style="margin-left: 1rem;">Salir</a>
        </span>
    </div>

    <div class="hero">
        <h2>Explora y Reserva Tu Cancha</h2>
        <p>Selecciona una fecha exacta para descubrir los horarios disponibles y jugar tu próximo partido.</p>
        <form action="/client/catalog" method="GET" class="search-box">
            <input type="date" name="date" value="<%= selectedDate %>" required>
            <button type="submit">Cargar Turnos Disponibles</button>
        </form>
    </div>

    <div class="container">
        <% if(selectedDate) { %>
            <div style="background: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; padding: 1rem 1.5rem; border-radius: 0.5rem; margin-bottom: 2rem; display:inline-block;">
                <h3 style="margin: 0; color: #cbd5e1; font-weight: 500;">Mostrando turnos para el día: <span style="color: #10b981; font-weight:bold;"><%= selectedDate %></span></h3>
            </div>
        <% } %>

        <div class="courts-grid">
            <% courts.forEach(court => { %>
                <div class="court-card">
                    <img src="<%= court.image_url ? court.image_url : 'https://images.unsplash.com/photo-1579952363873-27f3bade9f55?q=80&w=600&auto=format&fit=crop' %>" alt="Cancha de deportes" class="court-image">
                    
                    <div class="court-info">
                        <h3 class="court-name"><%= court.name %> <span style="font-size: 0.85rem; color: #f59e0b; margin-left: 0.5rem;">| Calificación: <%= court.avgRating %></span></h3>
                        <div class="court-price">$<%= court.price_per_hour %> / turno de 1hs</div>
                        
                        <% if (selectedDate) { %>
                            <div class="schedules-container">
                                <div class="schedules-title">⌚ Turnos de este día</div>
                                <div class="blocks-grid">
                                    <% if (court.schedules && court.schedules.length > 0) { %>
                                        <% court.schedules.forEach(schedule => { 
                                            const time = schedule.startTime.substring(0, 5);
                                        %>
                                            <form action="/client/bookings" method="POST" style="margin: 0; padding: 0;">
                                                <input type="hidden" name="schedule_id" value="<%= schedule.id %>">
                                                <button type="submit" class="time-block" title="Siguiente paso: Reservar este turno"><%= time %></button>
                                            </form>
                                        <% }) %>
                                    <% } else { %>
                                        <div class="no-schedules" style="width: 100%;">Aún no hay turnos abiertos para esta fecha o ya están llenos.</div>
                                    <% } %>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="schedules-container" style="color: #64748b; font-size: 0.875rem; text-align:center; padding: 1rem; background: #0f172a; border-radius:0.5rem;">
                                Selecciona una fecha arriba para cargar los turnos.
                            </div>
                        <% } %>
                    </div>
                </div>
            <% }); %>
            
            <% if(courts.length === 0) { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; background: #1e293b; border-radius: 1rem; border: 1px dashed #475569;">
                    <h3 style="color: #94a3b8;">No hay canchas registradas en el sistema aún.</h3>
                </div>
            <% } %>
        </div>
    </div>
    <%- include('../components/layout/footer.ejs') %>
