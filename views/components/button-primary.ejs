<% 
  const btnText = locals.text || 'Action';
  const btnType = locals.type || 'button';
  const btnId = locals.id || '';
%>

<style>
  .btn-kinetic-primary {
      background: linear-gradient(135deg, #006d37 0%, #2ecc71 100%);
      color: white;
      border: none;
      padding: 1rem;
      font-family: 'Lexend', sans-serif;
      font-weight: 700;
      font-size: 1.125rem; 
      border-radius: 0.5rem;
      width: 100%;
      transition: all 0.2s ease;
      box-shadow: 0 10px 15px -3px rgba(0, 109, 55, 0.2), 0 4px 6px -2px rgba(0, 109, 55, 0.1); 
  }
  
  .btn-kinetic-primary:hover {
      transform: scale(1.02);
      color: white;
  }
  
  .btn-kinetic-primary:active {
      transform: scale(0.95);
  }
</style>

<button type="<%= btnType %>" id="<%= btnId %>" class="btn btn-kinetic-primary mt-2">
  <%= btnText %>
</button>