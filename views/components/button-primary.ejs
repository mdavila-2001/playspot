<% 
  const btnText = locals.text || 'Action';
  const btnType = locals.type || 'button';
  const btnId = locals.id || '';
%>

<style>
  .btn-kinetic {
    background: linear-gradient(135deg, #006d37 0%, #2ecc71 100%); /*  */
    color: #ffffff;
    border: none;
    border-radius: 0.5rem; /*  */
    padding: 0.75rem 1.5rem;
    font-family: 'Plus Jakarta Sans', sans-serif; /*  */
    font-weight: 600;
    transition: transform 0.2s ease-in-out;
    width: 100%;
  }

  .btn-kinetic:hover {
    transform: scale(1.02); /* Efecto spring-loaded  */
    color: #ffffff;
    box-shadow: 0 10px 20px -5px rgba(0, 109, 55, 0.3);
  }
</style>

<button type="<%= btnType %>" id="<%= btnId %>" class="btn btn-kinetic">
  <%= btnText %>
</button>