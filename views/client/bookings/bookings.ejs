<%- include('../../components/layout/header.ejs', { title: 'Mis Reservas - PlaySpot Cliente', hideNav: true, styles: ['/client/bookings/bookings.css', '/components/layout/styles/sidebar.css'] }) %>
<%- include('../../components/layout/client-sidebar.ejs', { activePage: 'bookings' }) %>

<main class="admin-main">
    <%- include('../../components/layout/client-topbar.ejs') %>
    
    <div class="admin-content-wrapper p-4 p-lg-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-4 mb-5">
            <div>
                <h1 class="display-5 fw-black font-headline tracking-tight mb-0 text-dark">Historial de Reservas</h1>
                <p class="text-secondary fw-medium">Gestiona tus partidos activos y pasados.</p>
            </div>
        </div>

            <div class="container">
                <h2 class="section-title">Reservas Activas</h2>
                <div class="table-container">
                    <div class="table-header">
                        <div class="col">CANCHA</div>
                        <div class="col">FECHA Y HORA</div>
                        <div class="col">ESTADO</div>
                        <div class="col">ACCIÓN</div>
                    </div>
                    <% if (activeBookings && activeBookings.length > 0) { %>
                        <% activeBookings.forEach(booking => { %>
                            <div class="table-row">
                                <div class="col"><strong><%= booking.schedule.court.name %></strong></div>
                                <%
                                    const dateStrB = String(booking.date);
                                    let displayDateB = dateStrB;
                                    if (dateStrB.includes('T')) {
                                        displayDateB = new Date(dateStrB).toLocaleDateString('es-MX');
                                    } else if (dateStrB.includes('-')) {
                                        const p = dateStrB.split('-');
                                        displayDateB = `${p[2]}/${p[1]}/${p[0]}`;
                                    }
                                %>
                                <div class="col"><%= displayDateB %> <br><span style="color:#64748b; font-size:0.85rem;"><%= booking.schedule.start_time.substring(0,5) %> - <%= booking.schedule.end_time.substring(0,5) %></span></div>
                                <div class="col"><span class="badge badge-primary">Confirmada</span></div>
                                <div class="col">
                                    <form action="/client/bookings/<%= booking.id %>/cancel" method="POST" style="margin:0;">
                                        <button type="submit" class="btn-cancel">Cancelar</button>
                                    </form>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="empty-state">No tienes reservas activas en este momento.</div>
                    <% } %>
                </div>

                <h2 class="section-title" style="margin-top: 3rem;">Historial Pasado</h2>
                <div class="table-container">
                    <div class="table-header">
                        <div class="col">CANCHA</div>
                        <div class="col">FECHA Y HORA</div>
                        <div class="col">ESTADO</div>
                        <div class="col">RESEÑA</div>
                    </div>
                    <% if (pastBookings && pastBookings.length > 0) { %>
                        <% pastBookings.forEach(booking => { %>
                            <div class="table-row">
                                <div class="col"><strong><%= booking.schedule.court.name %></strong></div>
                                <%
                                    const dateStrB = String(booking.date);
                                    let displayDateB = dateStrB;
                                    if (dateStrB.includes('T')) {
                                        displayDateB = new Date(dateStrB).toLocaleDateString('es-MX');
                                    } else if (dateStrB.includes('-')) {
                                        const p = dateStrB.split('-');
                                        displayDateB = `${p[2]}/${p[1]}/${p[0]}`;
                                    }
                                %>
                                <div class="col"><%= displayDateB %> <br><span style="color:#64748b; font-size:0.85rem;"><%= booking.schedule.start_time.substring(0,5) %> - <%= booking.schedule.end_time.substring(0,5) %></span></div>
                                <div class="col">
                                    <% if (booking.status === 'completed') { %>
                                        <span class="badge badge-success">Completada</span>
                                    <% } else { %>
                                        <span class="badge badge-danger">Cancelada</span>
                                    <% } %>
                                </div>
                                <div class="col" style="flex: 1.5;">
                                    <% 
                                        const now = new Date();
                                        const bookingDateStr = booking.date + 'T' + booking.schedule.end_time;
                                        const isPast = new Date(bookingDateStr) <= now;
                                    %>
                                    <% if (booking.status === 'completed') { %>
                                        <% if (!isPast) { %>
                                            <span style="color:#059669; font-size: 0.85rem; font-weight:600;"><i class="bi bi-clock-history"></i> Esperando partido</span>
                                        <% } else if (booking.is_reviewed) { %>
                                            <span style="background: #fef3c7; color: #b45309; padding: 0.3rem 0.6rem; border-radius: 999px; font-size: 0.8rem; font-weight:700;">
                                                <i class="bi bi-star-fill"></i> Reseña Publicada
                                            </span>
                                        <% } else { %>
                                            <form action="/client/bookings/review" method="POST" class="review-form">
                                                <input type="hidden" name="court_id" value="<%= booking.schedule.court.id %>">
                                                <input type="hidden" name="booking_id" value="<%= booking.id %>">
                                                <input type="hidden" name="rating" value="5" class="rating-value-input">
                                                
                                                <div class="star-rating">
                                                    <i class="bi bi-star-fill star-icon active" data-value="1"></i>
                                                    <i class="bi bi-star-fill star-icon active" data-value="2"></i>
                                                    <i class="bi bi-star-fill star-icon active" data-value="3"></i>
                                                    <i class="bi bi-star-fill star-icon active" data-value="4"></i>
                                                    <i class="bi bi-star-fill star-icon active" data-value="5"></i>
                                                </div>
                                                
                                                <input type="text" name="comment" placeholder="Comentario..." required>
                                                <button type="submit" class="btn-review">Enviar</button>
                                            </form>
                                        <% } %>
                                    <% } else { %>
                                        <span style="color:#94a3b8; font-size: 0.85rem;"><i class="bi bi-x-circle"></i> Cancelado</span>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="empty-state">No tienes historial de reservas.</div>
                    <% } %>
                </div>
            </div>
    </div>
</main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const reviewForms = document.querySelectorAll('.review-form');
            reviewForms.forEach(form => {
                const stars = form.querySelectorAll('.star-icon');
                const ratingInput = form.querySelector('.rating-value-input');
                
                stars.forEach(star => {
                    star.addEventListener('mouseover', function() {
                        const val = this.getAttribute('data-value');
                        stars.forEach(s => {
                            if (s.getAttribute('data-value') <= val) {
                                s.classList.add('hover');
                            } else {
                                s.classList.remove('hover');
                            }
                        });
                    });
                    
                    star.addEventListener('mouseout', function() {
                        stars.forEach(s => s.classList.remove('hover'));
                    });
                    
                    star.addEventListener('click', function() {
                        const val = this.getAttribute('data-value');
                        ratingInput.value = val;
                        stars.forEach(s => {
                            if (s.getAttribute('data-value') <= val) {
                                s.classList.add('active');
                            } else {
                                s.classList.remove('active');
                            }
                        });
                    });
                });
            });
        });
    </script>
    <%- include('../../components/layout/footer.ejs') %>
