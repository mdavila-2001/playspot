<%- include('../../components/layout/header.ejs', { title: 'Control de Reservas | Admin' }) %>
<%- include('../../components/layout/admin-sidebar.ejs') %>

<main class="admin-main">
    <%- include('../../components/layout/admin-topbar.ejs') %>
    <div class="admin-content-wrapper p-4 p-lg-5">
        
        <header class="mb-5">
            <h1 class="display-5 fw-black font-headline tracking-tight text-dark mb-1">CONTROL DE RESERVAS</h1>
            <p class="text-secondary fw-medium">Seguimiento de usuarios y ocupación de espacios en tiempo real.</p>
        </header>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="bg-white p-4 rounded-4 shadow-sm d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-success-subtle text-success p-3">
                        <i class="bi bi-cash-stack fs-4"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-0">Ingresos Hoy</p>
                        <p class="fs-4 fw-black font-headline mb-0">$<%= stats.earningsToday.toLocaleString('en-US', { minimumFractionDigits: 2 }) %></p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-white p-4 rounded-4 shadow-sm d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-warning-subtle text-warning p-3">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-0">Confirmadas</p>
                        <p class="fs-4 fw-black font-headline mb-0"><%= stats.confirmedCount %></p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-white p-4 rounded-4 shadow-sm d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-danger-subtle text-danger p-3">
                        <i class="bi bi-x-circle-fill fs-4"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-0">Canceladas</p>
                        <p class="fs-4 fw-black font-headline mb-0"><%= stats.cancelledCount %></p>
                    </div>
                </div>
            </div>
        </div>

        <section class="space-y-3">
            <div class="row px-4 py-3 text-muted small fw-bold text-uppercase letter-spacing-1 d-none d-md-flex">
                <div class="col-3">Usuario</div>
                <div class="col-3">Área / Cancha</div>
                <div class="col-3">Horario</div>
                <div class="col-2">Estado</div>
                <div class="col-1 text-end">Acciones</div>
            </div>

            <% if (bookings && bookings.length > 0) { %>
                <% bookings.forEach(booking => { %>
                    <div class="row mx-0 align-items-center p-4 mb-3 shadow-sm booking-card-row">
                        <div class="col-12 col-md-3 d-flex align-items-center gap-3 mb-3 mb-md-0">
                            <div>
                                <p class="mb-0 fw-bold text-dark font-lexend"><%= booking.user.name %></p>
                                <p class="mb-0 text-muted small">ID: PS-<%= booking.id %></p>
                            </div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-emerald"><%= booking.schedule.court.name %></span>
                            </div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="d-flex flex-column">
                                <%
                                    const dateStrA = String(booking.schedule.fecha);
                                    let displayDateA = dateStrA;
                                    if (dateStrA.includes('T')) {
                                        displayDateA = new Date(dateStrA).toLocaleDateString('es-MX');
                                    } else if (dateStrA.includes('-')) {
                                        const p = dateStrA.split('-');
                                        displayDateA = `${p[2]}/${p[1]}/${p[0]}`;
                                    }
                                %>
                                <span class="small fw-bold text-dark"><%= displayDateA %></span>
                                <span class="text-muted" style="font-size: 0.75rem;"><%= booking.schedule.start_time.slice(0, 5) %> - <%= booking.schedule.end_time.slice(0, 5) %></span>
                            </div>
                        </div>

                        <div class="col-6 col-md-2 mt-3 mt-md-0">
                            <% 
                                let statusClass = 'bg-secondary-subtle text-secondary';
                                let statusText = 'Otro';
                                if(booking.status === 'confirmed') {
                                    statusClass = 'bg-success-subtle text-success';
                                    statusText = 'Confirmada';
                                } else if(booking.status === 'cancelled') {
                                    statusClass = 'bg-danger-subtle text-danger';
                                    statusText = 'Cancelada';
                                } else if(booking.status === 'completed') {
                                    statusClass = 'bg-info-subtle text-info';
                                    statusText = 'Completada';
                                }
                            %>
                            <span class="status-pill <%= statusClass %>">
                                <div class="status-dot"></div>
                                <%= statusText %>
                            </span>
                        </div>

                        <div class="col-6 col-md-1 text-end mt-3 mt-md-0">
                            <div class="d-flex justify-content-end gap-2">
                                <% if(booking.status === 'confirmed') { %>
                                    <form action="/admin/bookings/complete/<%= booking.id %>" method="POST" class="m-0" onsubmit="return confirm('¿El cliente ya pagó? ¿Deseas marcar esta reserva como COMPLETADA en caja?');">
                                        <button class="btn btn-sm btn-light text-success border-0 rounded-3 shadow-sm" title="Marcar como Completada y Pagada">
                                            <i class="bi bi-check-circle-fill"></i>
                                        </button>
                                    </form>
                                    <form action="/admin/bookings/cancel/<%= booking.id %>" method="POST" class="m-0" onsubmit="return confirm('¿Estás seguro de que deseas cancelar esta reserva por inasistencia? Esta acción no se puede deshacer.')">
                                        <button class="btn btn-sm btn-light text-danger border-0 rounded-3 shadow-sm" title="Cancelar Reserva">
                                            <i class="bi bi-x-circle-fill"></i>
                                        </button>
                                    </form>
                                <% } else { %>
                                    <span class="text-muted small italic">Sin acciones</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center p-5 bg-white rounded-4 shadow-sm">
                    <i class="bi bi-calendar-x fs-1 text-muted mb-3 d-block"></i>
                    <p class="text-secondary fw-medium">No se encontraron registros de reservas.</p>
                </div>
            <% } %>
        </section>

    </div>
    <%- include('../../components/layout/footer.ejs') %>
</main>